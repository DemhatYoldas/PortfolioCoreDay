@model List<PortfolioCoreDay.Entities.Testimonial>

@{
    ViewData["Title"] = "TestimonialListe";
    Layout = "~/Views/AdminLayout/Index.cshtml";
}

<h2>Referans İşlemleri</h2>

<table class="table table-bordered">
<tr>
    <th>Id</th>
    <th>Referans Adı</th>
    <th>Referans Unvanı</th>
    <th>Açıklama</th>
    <th>Sil</th>
    <th>Güncelle</th>
</tr>

@foreach (var item in Model)
{
    <tr>
        <td>@item.TestimonialId</td>
        <td>@item.NameSurname</td>
        <td>@item.Title</td>
        <td>@item.Description</td>
        <td><a href="" class="btn btn-danger">Sil</a></td>
        <td><a href="" class="btn btn-success">Güncelle</a></td>
    </tr>
}
</table>
<a href="" class="btn btn-primary">Yeni Referans Girişi</a>