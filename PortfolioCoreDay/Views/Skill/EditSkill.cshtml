@model Skill
@{
    ViewData["Title"] = "EditSkill";
    Layout = "~/Views/AdminLayout/Index.cshtml";
}




<h1> Yetenek Güncelle</h1>

<form method="post">

    <input type="hidden" asp-for="Id" />

    <label> Yetenek Adı </label>
    <input type="text" asp-for="SkillName" class="form-control" style="border:1px solid black;" />
    <br />

    <label>Yetenek Değeri</label>
    <input type="text" asp-for="SkillValue" class="form-control" style="border:1px solid black;" />
    <br />


    <button class="btn btn-primary">Yetenek Güncelle</button>

</form>