@model Testimonial
@{
    ViewData["Title"] = "UpdateTestimonial";
    Layout = "~/Views/AdminLayout/Index.cshtml";
}

<h1>Referans Güncelle</h1>


<form method="post">

    <input type="hidden" asp-for="TestimonialId" />

    <label>Ad Soyad</label>
    <input type="text" asp-for="NameSurname" class="form-control" style="border:1px solid black;" />
    <br />

    <label>Referans Ünvanı</label>
    <input type="text" asp-for="Title" class="form-control" style="border:1px solid black;" />
    <br />

    <label>Görsel Url</label>
    <input type="text" asp-for="ImageUrl" class="form-control" style="border:1px solid black;" />
    <br />

    <label>Referans Açıklama</label>
<textarea class="form-control" asp-for="Description" rows="3" style="border:1px solid black;"></textarea>
    <br />

    <button class="btn btn-success">Referansı Güncelle</button>

</form>